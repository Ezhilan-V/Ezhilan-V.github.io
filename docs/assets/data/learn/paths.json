    {
      "id": "navigation",
      "title": "Mobile-robot navigator",
      "tagline": "Build a robot that drives anywhere safely",
      "icon": "fa-compass",
      "accent": "#34d399",
      "audience": "Wants to deliver mobile robots - AMRs, delivery, hospital, warehouse.",
