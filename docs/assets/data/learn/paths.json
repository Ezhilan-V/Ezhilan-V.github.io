{
  "intro": {
    "title": "Learning Paths",
    "tagline": "From your first day to a working robot - the order to learn things in",
    "body": "Robotics is wide. The catalog has every branch and every section, but a newcomer needs an order. Each path below sequences the sections you'd actually read in real life, level by level, with checkpoints. Pick the one that matches your goal."
  },
  "paths": [
    {
      "id": "ground-up",
      "title": "Ground-up generalist",
      "tagline": "Zero → useful in 8 weeks",
      "icon": "fa-seedling",
      "accent": "#34d399",
      "audience": "Brand new to robotics. Comfortable with Python and a little linear algebra.",
      "duration": "≈ 8 weeks (10 hr / week)",
      "modules": [
        {
          "level": "beginner",
          "label": "Week 1–2  ·  Setup + foundations",
          "summary": "Get your machine working, pick up the prerequisites you'll need.",
          "stops": [
            { "branch": "setup",        "section": "ros2-jazzy",         "label": "Install ROS 2 Jazzy" },
            { "branch": "setup",        "section": "colcon-ws",          "label": "Make a colcon workspace" },
            { "branch": "setup",        "section": "gazebo",             "label": "Bring up Gazebo" },
            { "branch": "foundations",  "section": "linear-algebra",     "label": "Linear algebra refresh" },
            { "branch": "foundations",  "section": "probability-stats",  "label": "Probability + stats refresh" }
          ]
        },
        {
          "level": "beginner",
          "label": "Week 3–4  ·  The body + math of motion",
          "summary": "Frames, kinematics, and the URDF that lets ROS see your robot.",
          "stops": [
            { "branch": "mechanical-design", "section": "rigid-body-basics",    "label": "Rigid bodies + DoF" },
            { "branch": "mechanical-design", "section": "frames-rotations",     "label": "Frames + rotations" },
            { "branch": "mechanical-design", "section": "forward-kinematics",   "label": "Forward kinematics" },
            { "branch": "mechanical-design", "section": "urdf-modelling",       "label": "URDF / xacro" }
          ]
        },
        {
          "level": "intermediate",
          "label": "Week 5–6  ·  Sense + perceive",
          "summary": "Get pixels and depth into ROS, and turn them into beliefs.",
          "stops": [
            { "branch": "sensors",          "section": "cameras",              "label": "Camera taxonomy" },
            { "branch": "sensors",          "section": "imu",                  "label": "IMU basics" },
            { "branch": "computer-vision",  "section": "camera-fundamentals",  "label": "Pinhole camera model" },
            { "branch": "computer-vision",  "section": "image-processing",     "label": "OpenCV image processing" },
            { "branch": "computer-vision",  "section": "object-detection",     "label": "Deep object detection" }
          ]
        },
        {
          "level": "intermediate",
          "label": "Week 7–8  ·  Drive a robot",
          "summary": "Localize, plan, and drive with Nav2.",
          "stops": [
            { "branch": "navigation", "section": "the-loop",                 "label": "The nav loop" },
            { "branch": "navigation", "section": "robot-kinematics",         "label": "Mobile robot kinematics" },
            { "branch": "navigation", "section": "bayes-filter-intuition",   "label": "Bayes filter intuition" },
            { "branch": "navigation", "section": "slam",                     "label": "Build a map with slam_toolbox" },
            { "branch": "navigation", "section": "nav2-bringup",             "label": "Bring up Nav2" }
          ]
        },
        {
          "level": "advanced",
          "label": "Stretch  ·  Ship a project",
          "summary": "Pick one of these starter projects, finish it, demo it.",
          "stops": [
            { "branch": "setup", "section": "learning-paths", "label": "Pick a starter project" },
            { "branch": "setup", "section": "first-week",     "label": "First-week plan" }
          ]
        }
      ]
    },
    {
