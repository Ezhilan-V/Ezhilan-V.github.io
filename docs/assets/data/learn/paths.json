            { "branch": "control-systems",  "section": "force-impedance",  "label": "Impedance control" },
            { "branch": "manipulation",     "section": "grasping",         "label": "Grasping fundamentals" },
            { "branch": "manipulation",     "section": "ros2-control",     "label": "ros2_control" }
          ]
        },
        {
          "level": "advanced",
          "label": "Modern dexterity",
          "summary": "Where research is in 2026.",
          "stops": [
            { "branch": "ai-ml",       "section": "imitation-learning", "label": "Imitation learning" },
            { "branch": "ai-ml",       "section": "diffusion-policies", "label": "Diffusion policies" },
            { "branch": "ai-ml",       "section": "vla-models",         "label": "VLA models" },
            { "branch": "manipulation","section": "bimanual",           "label": "Bimanual manipulation" }
          ]
        }
      ]
