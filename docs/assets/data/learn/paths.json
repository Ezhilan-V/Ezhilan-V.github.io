            { "branch": "navigation", "section": "costmaps",                "label": "Costmaps + inflation" },
            { "branch": "navigation", "section": "planners-and-controllers","label": "Planners + controllers" },
            { "branch": "navigation", "section": "astar-playground",        "label": "Try it: A* pathfinding" },
            { "branch": "navigation", "section": "behavior-trees",          "label": "Behavior trees" }
          ]
        },
        {
          "level": "advanced",
          "label": "Fleets + production",
          "summary": "When one robot becomes ten.",
          "stops": [
            { "branch": "amr",         "section": "fleet-architecture", "label": "Fleet architecture" },
            { "branch": "amr",         "section": "vda-5050",           "label": "VDA 5050" },
            { "branch": "multi-robot", "section": "mapf",               "label": "MAPF" }
